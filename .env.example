# Vercel Dashboard → Settings → Environment Variables 에 추가
GEMINI_API_KEY=your_gemini_api_key_here

# Supabase (https://supabase.com)
# Settings → API → Project URL (DB URL 아님!)
SUPABASE_URL=https://your-project-id.supabase.co
# Settings → API → service_role → secret (anon key 아님!)
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# Settings → Data API → Exposed schemas 에 public 포함 확인
# supabase/schema.sql → SQL Editor에서 실행
